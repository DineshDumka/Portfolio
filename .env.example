# ─────────────────────────────────────────────
# Contact Form — Formspree
# ─────────────────────────────────────────────
# 1. Go to https://formspree.io and create a free account
# 2. Create a new form, set the email to dineshdumka27@gmail.com
# 3. Copy your Form ID (the part after /f/ in the endpoint URL)
# 4. Paste it below — it looks like: xpwdbzky
#
# Free tier: 50 submissions/month, spam filtering included.
# NEXT_PUBLIC_ prefix is required (used in client-side code).
NEXT_PUBLIC_FORMSPREE_ID=your_formspree_form_id_here

# ─────────────────────────────────────────────
# Resend (optional — legacy server-side route)
# ─────────────────────────────────────────────
# Only needed if you switch back to the /api/contact server route.
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_EMAIL=dineshdumka27@gmail.com
